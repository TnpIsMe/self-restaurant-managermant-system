#
# Ví dụ local (SQL auth):
# DATABASE_URL="sqlserver://localhost:1433;database=self_restaurant;user=sa;password=YourPassword123;encrypt=false;trustServerCertificate=true"
#
# Ví dụ Azure SQL:
# DATABASE_URL="sqlserver://yourserver.database.windows.net:1433;database=self_restaurant;user=adminuser;password=YourPassword123;encrypt=true"

